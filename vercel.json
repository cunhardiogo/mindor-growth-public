{
  "crons": [
    {
      "path": "/api/cron/ig-snapshot",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/erp-sync",
      "schedule": "0 4 * * *"
    }
  ],
  "rewrites": [
    { "source": "/asaas-api/:path*", "destination": "/api/asaas/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co https://api.asaas.com; font-src 'self' data: https://fonts.gstatic.com" }
      ]
    }
  ]
}
